# ==========================================
# StadiumIQ Production Environment Template
# Fill in production values and load them in your environment
# ==========================================

# Database Connection URI (PostgreSQL with pgvector)
# Replace 'db-host' with your production PostgreSQL server address or VM internal name
DATABASE_URL="postgresql://admin:YOUR_PRODUCTION_DB_PASSWORD@postgres-db:5432/stadiumiq?schema=public"

# Redis Cache connection URI
# Replace with production Redis cache server address
REDIS_URL="redis://redis-cache:6379"

# Generative AI Key (Gemini API)
# Get a key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY="YOUR_GEMINI_PRODUCTION_API_KEY"

# JWT Authentication Secrets (For Production APIs)
JWT_SECRET="YOUR_PRODUCTION_JWT_SECRET_SIGNING_KEY"

# InfluxDB Configuration for Live Telemetry
INFLUX_URL="http://influx-db:8086"
INFLUX_TOKEN="YOUR_PRODUCTION_INFLUX_TOKEN"
INFLUX_ORG="stadiumiq_org"
INFLUX_BUCKET="telemetry_bucket"

# MinIO/S3 Storage Configuration
MINIO_ROOT_USER="admin"
MINIO_ROOT_PASSWORD="YOUR_PRODUCTION_MINIO_PASSWORD"

# OpenSearch Configuration
OPENSEARCH_INITIAL_ADMIN_PASSWORD="YOUR_STRONG_OPENSEARCH_ADMIN_PASSWORD"
